native function list<string> contents_of(room r)

# All of the printing for room description is in here, including
# listing contents, and whatever else we may want to add.
function void describe_room(room r):
	print r
	print r.description
	list_room_contents(r)

function void list_room_contents(room r):
	let contents = contents_of(r)
	if not (contents.first == none):
		print
		print "You see " + contents + " here."

on person.holder change:
	describe_room(player.holder)