#advent types

type thing:
	string printed_name
	string understand

type article

type game:
	room start

type physical < thing:
	article article

type container < physical

type room < container:
	string description

type item < physical:
	bool scenery
	container holder

type box < item, container:
	bool closable
	bool closed

type person < physical:
	container holder

type direction < thing:
	direction inverse
