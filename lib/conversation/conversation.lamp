lib advent

# Conversation subsystem — ASK/TELL ABOUT a topic. Kept in its own library because conversation
# style is a matter of taste: an advent game opts in with `lib conversation` rather than getting
# it baked into core. Declare it AFTER `lib advent` (it references advent's `physical`/`thing`)
# and before the game.
#
# A `subject` is an abstract topic: a `thing` (so it has a printed name + `understand` vocab) but
# NOT `physical`, so the parser resolves a `[topic]` slot against every subject in the world
# rather than by scope (resolvePool treats non-physical slot types as globally referable — the
# same path directions use). A game declares one subject per topic and sets its `reply` (the
# answer when ASKED); dynamic or per-interlocutor responses come from `instead`/`after ask`
# (or `tell`) rules guarded on `self.topic` / `self.interlocutor`.

type subject < thing:
	# The interlocutor's reply when ASKED about this topic. Empty → the default puzzled message.
	string reply = ""

# GREET / TALK TO — the conversational opener (devdocs/conversation.md). Deliberately modest:
# the default nudges the player toward ASK/TELL ("The hacker waits for you to say something."),
# and a game gives an NPC a real opening with `instead greet when self.interlocutor == hacker`.
# The comma templates catch the addressed greeting ("hacker, hello") ahead of the engine's
# X,-COMMAND fallback — greeting is the PLAYER's act, never an order. `visible`: talking is
# vocal, so it works through the glass booth (devdocs/accessibility.md).
action greet:
	direct visible physical interlocutor
	syntax:
		"talk to [interlocutor]"
		"greet [interlocutor]"
		"say hello to [interlocutor]"
		"[interlocutor] , hello"
		"[interlocutor] , hi"

check greet:
	if not (self.interlocutor is person):
		stop failed greet_not_person

report greet:
	print greet_default:"[The act.interlocutor] [wait] for [us] to say something."

report failed greet when self.reason == greet_not_person:
	print greet_no_reply:"[We] [get] no reply."

# Bare HELLO with no addressee. No guess-the-addressee magic (that would belong to command
# inference); just a retheme-able pleasantry.
action hello:
	syntax:
		"hello"
		"hi"

report hello:
	print hello_reply:"Cheery, aren't you?"

# ASK <someone> ABOUT <topic>. The interlocutor is a `physical` (in scope); the topic is any
# `thing` — a declared `subject` (with its stock `reply`) or a PHYSICAL OBJECT by name
# ("ask hacker about moonstone"), resolved globally in both cases (conversation may reference
# what is elsewhere — you remember it). A physical topic has no `reply`, so it falls to the
# puzzled default unless a game rule answers (`instead ask when self.topic == moonstone`).
# `direct` sits on the topic, so "ask her about the stone. x it" tracks the stone.
action ask:
	visible physical interlocutor
	direct thing topic
	syntax:
		"ask [interlocutor] about [topic]"

report ask:
	if (self.topic is subject) and not (self.topic.reply == ""):
		print "[self.topic.reply]"
	else:
		print convo_no_reply:"[The act.interlocutor] [have] nothing to say about that."

# TELL <someone> ABOUT <topic>. Informing rather than querying: no stock answer, so the default
# is a neutral non-reaction; a game adds `instead tell when self.topic == X` for topics that land.
action tell:
	visible physical interlocutor
	direct thing topic
	syntax:
		"tell [interlocutor] about [topic]"

report tell:
	print convo_not_interested:"[The act.interlocutor] [do] not seem interested."

# SAY / ANSWER free text. Unlike ASK/TELL ABOUT — which resolve a declared `[topic]` subject
# object — this matches whatever the player typed as a raw `string`, captured verbatim (and
# lowercased by the parser). So a game responds to specific *utterances* ("yes", "no", "i am
# human") with `instead say` rules guarded on `self.topic`, rather than to declared topics.
# SAY fails by default (there's no listener, or nothing the listener reacts to); a game adds
# `instead say` rules for the utterances that land and `stop succeeded`, letting anything its
# guards don't match fall through (no `stop`) to the default reply.

# The optional `interlocutor` slot is never bound by these templates — the engine's addressing
# parser fills it when an order's remainder parses as nothing ("urchin, boo" → say "boo" TO the
# urchin; devdocs/conversation.md), so a game hooks the directed form with
# `instead say when self.topic == "boo" and self.interlocutor == urchin`. Plain SAY leaves it
# unset, and any guard against a specific person is simply false.
action say:
	string topic
	visible physical interlocutor
	syntax:
		"say [topic]"
		"answer [topic]"

check say:
	stop failed nothing_to_say

report failed say when self.reason == nothing_to_say:
	print say_no_reply:"There is no reply."
