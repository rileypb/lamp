# Exercises disambiguation: two items share a vocabulary token; player is
# prompted and answers via the normal command loop to narrow the choice.

lib advent

game Test_Disambig:
	author "Test Author"
	version 1
	release dev
	start Foyer

room Foyer:
	description "A foyer."

item brass_lamp:
	understand "lamp/brass"

item clay_lamp:
	understand "lamp/clay"

contains Foyer brass_lamp
contains Foyer clay_lamp
