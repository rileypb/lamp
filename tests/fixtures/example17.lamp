lib test

game Example_17:
    author "Test Author"
    version 1
    release dev

on startup:
    let a = 10 - 3
    print (a) + "[line break]"
    let b = 20 / 4
    print (b) + "[line break]"
    let c = 2 ^ 8
    print (c) + "[line break]"
    let d = 1 + 2 * 3
    print (d) + "[line break]"
    let e = 2 ^ 3 ^ 2
    print (e) + "[line break]"
