# The fr-FR locale pack, selected by a `locale "fr-FR"` source declaration (so
# the golden runner compiles it against lib/fr-FR with no flag). Exercises the
# French language layer: gendered articles le/la/l'/les and un/une/des with
# elision before a vowel or h, proper names (no article), French list prose
# (" et ", no serial comma), copula est/sont, number words (the tricky 70/80/90
# forms), small ordinals, and case transforms. See devdocs/i18n.md.

locale "fr-FR"

game Locale_FR:
    author "Lamp"

type thing:
    string printed_name = ""
    string grammatical_gender = "masculine"
    bool plural = false
    bool proper = false

thing crochet
thing lampe:
    grammatical_gender "feminine"
thing armoire:
    grammatical_gender "feminine"
thing horloge:
    grammatical_gender "feminine"
thing cles:
    printed_name "clés"
    grammatical_gender "feminine"
    plural
thing alice:
    printed_name "Alice"
    proper

on startup:
    print "Défini : [le crochet], [le lampe], [le armoire], [le horloge], [le cles], [le alice]."
    print "Indéfini : [un crochet], [un lampe], [un armoire], [un cles], [un alice]."
    print "Capitale : [Le crochet] brille ; [Le armoire] aussi."
    print "Liste définie : [the_list(thing.all)]."
    print "Liste indéfinie : [a_list(thing.all)]."
    print "Copule : un objet [are(1)] là, deux objets [are(2)] là."
    print "Nombres : [in_words(21)], [in_words(71)], [in_words(80)], [in_words(90)], [in_words(97)], [in_words(100)], [in_words(200)], [in_words(1000)]."
    print "Ordinaux : [ordinal(1)], [ordinal(2)], [ordinal(5)], [ordinal(9)]."
    print "Casse : [cap(lampe.name)] ; [upper(crochet.name)] ; [lower(alice.printed_name)]."
