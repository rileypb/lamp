type room:
    string description

type direction:
    direction inverse

relation connects:
    room source
    direction dir inverted
    room target
    syntax "connects [source] [dir] to [target]"

direction north:
    inverse south
direction south:
    inverse north
direction east:
    inverse west
direction west:
    inverse east

room foyer:
    description "You're in the foyer."
room hall:
    description "You're in the hall."
room study:
    description "You're in the study."
