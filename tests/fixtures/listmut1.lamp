# List literals + element assignment (mutable lists). Covers a global list
# (literal init, element read + write) and a local list, plus undo durability:
# a mutated element reverts on undo (the snapshot deep-copies items at capture).

lib advent

game ListMut:
	start Room

room Room:
	description "A room."

global list<int> nums = none

rule startup_rules:
	nums = [10, 20, 30]

action setone:
	int n
	syntax:
		"set [n]"
do setone:
	nums[0] = self.n
report setone:
	let v = nums[0]
	print "set first = [v]."

action dump:
	syntax:
		"dump"
report dump:
	let a = nums[0]
	let b = nums[1]
	let c = nums[2]
	print "nums = [a], [b], [c] (size [nums.size])."
	let xs = [1, 2, 3]
	xs[2] = 9
	let last = xs[2]
	print "local last = [last]."
