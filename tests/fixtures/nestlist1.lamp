# Recursive contents listing: nested containers/supporters render with parenthetical
# contents. Exercises deep nesting (chest>thimble>marble), a supporter ("on which"),
# and plural copula ("in which are a coin and a gem"). The leaf items are bodyless
# nested objects (smart disambiguation: `item marble` nests without a body).

lib advent

game Nest_List:
	author "Test Author"
	start vault

room vault:
	description "A treasure vault."
	item chest:
		item thimble:
			item marble
	item pedestal:
		supporter
		item crate:
			item ball
	item bag:
		item coin
		item gem
