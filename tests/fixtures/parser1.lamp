# Game Parser v0 end-to-end: typed commands -> grammar match -> noun resolution
# against scope -> action rulebook. Self-contained world model.

game Parser_Demo:
	author "Test Author"
	version 1

type physical
type container < physical
type room < container:
	string description
type item < physical
type person < physical

person yourself

room Kitchen:
	description "A small kitchen."

item apple
item knife

# Containment as a relation — the runtime computes scope over `contains`.
relation contains:
	from physical place
	to physical contained unique
	syntax "contains [place] [contained]"

# An object's container: the source of its `contains` edge.
function physical holder(physical x):
	return contains ?only x

contains Kitchen apple
contains Kitchen knife

global person player = yourself

action look:
	syntax:
		"look"

action take:
	item taken
	syntax:
		"take [taken]"
		"get [taken]"

action drop:
	item taken
	syntax:
		"drop [taken]"

do look:
	print holder(self.actor).description

check take:
	if holder(self.taken) == player:
		print "You already have that."
		stop failed

do take:
	move self.taken to player
	print "Taken."

do drop:
	move self.taken to holder(player)
	print "Dropped."

on startup:
	move player to Kitchen
	print holder(player).description
	while true:
		let line = readline()
		if line == "quit":
			break
		run_command(line, player)
