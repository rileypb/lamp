# Game Parser pronoun "it": a bare "it" noun resolves to the last object the
# player referred to (the antecedent), gated by scope. See devdocs/game_parser.md.

game Pronoun_Demo:
	author "Test Author"
	version 1

type physical
type container < physical
type room < container:
	string description
type item < physical:
	string description
type person < physical

person yourself

room Kitchen:
	description "A small kitchen."

item apple:
	description "A shiny red apple."

item knife:
	description "A sharp knife."

# Containment as a relation — the runtime computes scope over `contains`.
relation contains:
	from physical place
	to physical contained unique
	syntax "contains [place] [contained]"

# An object's container: the source of its `contains` edge.
function physical holder(physical x):
	return contains ?only x

contains Kitchen apple
contains Kitchen knife

global person player = yourself

action take:
	direct item taken
	syntax:
		"take [taken]"
		"get [taken]"

action drop:
	direct item taken
	syntax:
		"drop [taken]"

action examine:
	direct item target
	syntax:
		"examine [target]"
		"x [target]"

check take:
	if holder(self.taken) == player:
		print "You already have that."
		stop failed

do take:
	move self.taken to player
	print "Taken."

do drop:
	move self.taken to holder(player)
	print "Dropped."

do examine:
	print self.target.description

on startup:
	move player to Kitchen
	print holder(player).description
	while true:
		let line = readline()
		if line == "quit":
			break
		run_command(line, player)
