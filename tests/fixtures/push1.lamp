# The generic PUSH action (lib/advent): PUSH any item, with a default "Nothing obvious
# happens." The target is `direct`, so the pronoun "it" refers back to the last-named thing.
# A game overrides the named `push_inert` message or adds `instead push` rules for controls
# that respond — here a button that opens a hatch.

lib advent

game Push:
	start Room

room Room:
	description "A bare room."

item lever
item button:
	description "A red button."

box hatch:
	closable true
	closed true
	description "A floor hatch."

contains Room lever
contains Room button
contains Room hatch

instead push when self.target == button:
	if hatch.closed:
		print "The button clicks. A floor hatch slides open."
		hatch.closed = false
	else:
		print "The button clicks, but nothing more happens."
	stop succeeded
