game Relation_12:
    author "Test Author"
    version 1
    release dev

type room
type direction

room foyer
room hall
direction north
direction south

relation connects:
    from room source
    direction dir
    to room target
    syntax "connects [source] [dir] [target]"

connects foyer north hall

on startup:
    if connects foyer north hall:
        print ("north exists") + "[line break]"
    if connects foyer south hall:
        print ("south exists") + "[line break]"
    else:
        print ("no south") + "[line break]"
