game Relation_15:
    author "Test Author"
    version 1
    release dev

type room
type direction

room foyer
room hall
direction north
direction south

relation connects:
    from room source
    direction dir
    to room target
    syntax "connects [source] [dir] [target]"

connects foyer north hall

on startup:
    if connects foyer north hall and not connects foyer south hall:
        print "exactly north"
    else:
        print "nope"
