game Relation_16:
    author "Test Author"
    version 1
    release dev

lib relations

bidi connects foyer north to hall
bidi connects hall east to study

on startup:
    let dest = connects foyer north to ?only
    print dest.description
    let back = connects hall south to ?only
    print back.description
    let nowhere = connects study north to ?only
    if nowhere == none:
        print "You can't go north from the study."
