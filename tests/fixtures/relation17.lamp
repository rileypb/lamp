game Relation_17:
    author "Test Author"
    version 1
    release dev

type room
type direction

room foyer
room hall
room study
direction north
direction east

relation connects:
    from room source
    direction dir
    to room target
    syntax "connects [source] [dir] [target]"

connects foyer north hall
connects foyer east study

on startup:
    print connects foyer _ ?all
    print connects foyer _ ?first
    print connects foyer ? hall
