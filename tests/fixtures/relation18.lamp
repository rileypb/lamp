game Relation_18:
    author "Test Author"
    version 1
    release dev

lib relations

global room here = foyer

bidi connects foyer north to hall
bidi connects hall east to study

function void go(direction d):
    let dest = connects here d to ?only
    if dest == none:
        print "You can't go that way."
    else:
        here = dest
        print here.description

on startup:
    go(north)
    go(east)
    go(west)
    go(north)
