game Relation_18:
    author "Test Author"
    version 1
    release dev

type room:
    string description
type direction:
    direction inverse

global room here = foyer

room foyer:
    description "You're in the foyer."
room hall:
    description "You're in the hall."
room study:
    description "You're in the study."

direction north:
    inverse south
direction south:
    inverse north
direction east:
    inverse west
direction west:
    inverse east

relation connects:
    room source
    direction dir inverted
    room target
    syntax "connects [source] [dir] [target]"

bidi connects foyer north hall
bidi connects hall east study

function void go(direction d):
    let dest = connects here d ?only
    if dest == none:
        print "You can't go that way."
    else:
        here = dest
        print here.description

on startup:
    go(north)
    go(east)
    go(west)
    go(north)
