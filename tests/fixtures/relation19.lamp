game Relation_19:
    author "Test Author"
    version 1
    release dev

lib relations

connects foyer north to hall

on startup:
    if connects foyer north to hall:
        print ("connected") + "[line break]"
    remove connects foyer north to hall
    if connects foyer north to hall:
        print ("still connected") + "[line break]"
    else:
        print ("disconnected") + "[line break]"
