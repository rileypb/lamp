game Relation_20:
    author "Test Author"
    version 1
    release dev

lib relations

north_door connects foyer north to hall

on startup:
    if connects foyer north to hall:
        print "connected[line break]"
    disconnect north_door
    if connects foyer north to hall:
        print "still connected[line break]"
    else:
        print "disconnected[line break]"
