game Relation_21:
    author "Test Author"
    version 1
    release dev

type room:
    string description

type direction:
    direction inverse

relation connects:
    room source
    direction dir inverted
    room target
    syntax "connects [source] [dir] [target]"

direction north:
    inverse south
direction south:
    inverse north
direction east:
    inverse west
direction west:
    inverse east

room foyer:
    description "You're in the foyer."
room hall:
    description "You're in the hall."
room study:
    description "You're in the study."

connects foyer north hall
connects foyer east study

on startup:
    print connects.all
    remove connects foyer _ _
    print connects.all
