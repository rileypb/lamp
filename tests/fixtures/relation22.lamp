game Relation_22:
    author "Test Author"
    version 1
    release dev

lib relations

# specificity 0 (fallback)
function void check():
    print "none"

# specificity 1: one bound slot
function void check() when connects foyer _ _:
    print "foyer has exit"

# specificity 3: three bound slots, wins over specificity 1
function void check() when connects foyer north hall:
    print "foyer connects north to hall"

on startup:
    check()
    connects foyer north hall
    check()
    remove connects foyer north _
    connects foyer east study
    check()
    remove connects _ _ _
    check()
