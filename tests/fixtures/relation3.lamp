game Relation_3:
    author "Test Author"
    version 1
    release dev

type room
type direction

room foyer
room hall
direction north
direction south

relation connects:
    from room source
    direction dir
    to room target

connects:
    source foyer
    dir north
    target hall

connects:
    source foyer
    dir north
    target hall

connects:
    source hall
    dir south
    target foyer

on startup:
    print "[connects.all][line break]"
