game Relation_5:
    author "Test Author"
    version 1
    release dev

type room
type direction

room foyer
room hall
direction north
direction south

relation connects:
    from room source
    direction dir
    to room target
    syntax "connects [source] [dir] [target]"

connects foyer north hall
connects foyer north hall
connects hall south foyer

on startup:
    print connects.all
