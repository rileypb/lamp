lib advent

# Regression: stored text templates must stay LIVE across undo AND save/restore — both a
# template reading a global (`reveal`) and one reading another named instance's field
# (`widget.level`, the named-instance branding path). The freeze bug turned them into dead
# strings showing the pre-undo/pre-restore values; the fix keeps them tracking live state.
# See devdocs/text-persistence.md.

global int reveal = 0

type gizmo:
    int level = 0

gizmo widget

action bump:
    syntax:
        "bump"

do bump:
    reveal = reveal + 1

# Targets the gizmo (self.target) rather than assigning a bare object name.
action tick:
    direct gizmo target
    syntax:
        "tick [target]"

do tick:
    self.target.level = self.target.level + 1

game TextLive:
    start hall

room hall:
    description "reveal=[reveal] level=[widget.level]."
